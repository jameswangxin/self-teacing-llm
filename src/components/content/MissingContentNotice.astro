---
interface Props {
  stageHref?: string | null;
  modulesHref?: string | null;
}

const { stageHref = null, modulesHref = null } = Astro.props;
---

<aside class="missing-content">
  <h2>内容暂缺</h2>
  <p>这个模块的正文还没有生成完成，请先返回阶段页或模块索引页继续学习。</p>
  {
    (stageHref || modulesHref) && (
      <p class="missing-content__actions">
        {stageHref && (
          <a class="missing-content__link" href={stageHref}>
            返回阶段页
          </a>
        )}
        {modulesHref && (
          <a class="missing-content__link" href={modulesHref}>
            查看模块索引
          </a>
        )}
      </p>
    )
  }
</aside>

<style>
  .missing-content {
    display: grid;
    gap: 0.75rem;
    padding: 1.2rem 1.25rem;
    border: 1px dashed rgba(15, 118, 110, 0.26);
    border-radius: calc(var(--radius-md) + 2px);
    background: rgba(255, 255, 255, 0.8);
  }

  .missing-content h2,
  .missing-content p {
    margin: 0;
  }

  .missing-content h2 {
    font-size: 1.25rem;
  }

  .missing-content p {
    color: var(--muted);
    line-height: 1.7;
  }

  .missing-content__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .missing-content__link {
    display: inline-flex;
    align-items: center;
    min-height: 2.6rem;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    font-weight: 700;
    color: var(--accent-strong);
    background: rgba(15, 118, 110, 0.1);
  }
</style>
